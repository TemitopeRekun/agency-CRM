# --- Database ---
# Use the Supabase connection string for production-like dev
DB_USER=postgres
DB_PASSWORD=YOUR_SUPABASE_PASSWORD
DB_NAME=postgres
# Host: db.fzizqugwmfgfxcsfbpfo.supabase.co
DB_HOST=localhost
DB_PORT=5432

# --- JWT Auth ---
# In production, use a long, random string (min 32 chars)
JWT_KEY=your_secret_key_here_min_32_chars
JWT_ISSUER=agency_crm
JWT_AUDIENCE=agency_crm

# --- API & Environment ---
ASPNETCORE_ENVIRONMENT=Development
API_PORT=8000

# --- Frontend ---
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
